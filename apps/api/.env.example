# ============================================================================
# Nexus API - Environment Variables
# Copy this file to .env and fill in your values
# ============================================================================

# Server
NODE_ENV=development
PORT=3001

# Database
DATABASE_URL=postgresql://nexus:nexus_password@localhost:5432/nexus_dev

# Redis (for queuing / caching)
REDIS_URL=redis://:redis_password@localhost:6379

# Clerk Authentication
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...

# Anthropic AI
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6

# Stripe Payments
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs (run `npx ts-node scripts/stripe-setup.ts` to create these)
# Starter: €299/mo — 1,000 workflow runs, 3 templates
STRIPE_PRICE_STARTER_MONTHLY=price_...
STRIPE_PRICE_STARTER_ANNUAL=price_...
STRIPE_PRICE_STARTER_METERED=price_...   # €0.04 per AI step above limit (metered)

# Professional: €999/mo — unlimited runs, all templates, full integrations
STRIPE_PRICE_PROFESSIONAL_MONTHLY=price_...
STRIPE_PRICE_PROFESSIONAL_ANNUAL=price_...

# Enterprise: €3,500/mo — custom SLAs, SOC 2, SSO, dedicated onboarding
STRIPE_PRICE_ENTERPRISE_MONTHLY=price_...

# Slack Integration
SLACK_TOKEN=xoxb-...

# Resend Email
RESEND_API_KEY=re_...

# CORS
ALLOWED_ORIGINS=http://localhost:3000,https://nexus.yourdomain.com

# Frontend URL (for Stripe portal redirects)
NEXTJS_URL=http://localhost:3000
